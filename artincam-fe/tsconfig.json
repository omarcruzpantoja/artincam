{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@assets/*": ["src/assets/*"],
      "@components/*": ["src/components/*"],
      "@services/*": ["src/services/*"],
      "@providers/*": ["src/providers/*"],
      "@reducers/*": ["src/reducers/*"],
      "@theme/*": ["src/theme/*"],
      "@types/*": ["src/types/*"],
      "@helpers/*": ["src/helpers/*"],
      "@lib/*": ["src/lib/*"],
      "@data/*": ["src/data/*"],
      "@root/*": ["src/*"]
    }
  }
}
